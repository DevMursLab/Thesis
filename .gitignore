data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.npy
*.pth
*.h5
*.pkl

# Results (generated — not source)
results/figures/*
results/metrics/*
!results/figures/.gitkeep
!results/metrics/.gitkeep

